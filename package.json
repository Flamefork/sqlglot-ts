{
	"name": "sqlglot-ts",
	"version": "0.1.2",
	"description": "SQL parser and transpiler for TypeScript - port of SQLGlot",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./dialects": {
			"types": "./dist/dialects/index.d.mts",
			"import": "./dist/dialects/index.mjs",
			"default": "./dist/dialects/index.mjs"
		},
		"./dialects/*": {
			"types": "./dist/dialects/*.d.mts",
			"import": "./dist/dialects/*.mjs",
			"default": "./dist/dialects/*.mjs"
		},
		"./expressions": {
			"types": "./dist/expressions.d.mts",
			"import": "./dist/expressions.mjs",
			"default": "./dist/expressions.mjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"check:format": "oxfmt --check src examples",
		"check:lint": "oxlint src examples",
		"check:types": "tsc --noEmit && tsc -p examples --noEmit",
		"check:architecture": "node tools/smoke/fluent_api_architecture_test.mjs",
		"check:codegen": "node tools/smoke/check_codegen_freshness.mjs",
		"check:api-surface": "npm run build && uv run --directory tools/python python api_surface.py",
		"test:examples": "node --experimental-strip-types --test examples/*.test.ts",
		"test:compat:duckdb": "npm run test:compat -- -k TestDuckDB",
		"test:compat": "uv run --directory tools/python pytest",
		"test:packaging:runtime": "bash tools/smoke/packaging_test.sh",
		"test:packaging:types": "bash tools/smoke/packaging_types_test.sh",
		"test:packaging": "npm run test:packaging:runtime && npm run test:packaging:types",
		"verify:fast": "npm run check:format && npm run check:lint && npm run check:types && npm run test:examples && npm run check:architecture",
		"verify:ci": "npm run verify:fast && npm run test:packaging && npm run check:codegen && npm run check:api-surface",
		"verify:full": "npm run verify:ci && npm run test:compat",
		"test": "npm run verify:fast",
		"fix:format": "oxfmt src examples",
		"fix:lint": "oxlint --fix src examples",
		"fix": "npm run fix:format && npm run fix:lint",
		"generate": "uv run --directory tools/python generate.py",
		"release:prepare": "npm run verify:ci",
		"release": "bash tools/release/release.sh"
	},
	"keywords": [
		"sql",
		"parser",
		"transpiler",
		"ast",
		"duckdb"
	],
	"author": "Ilia Ablamonov",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Flamefork/sqlglot-ts.git"
	},
	"homepage": "https://github.com/Flamefork/sqlglot-ts#readme",
	"bugs": {
		"url": "https://github.com/Flamefork/sqlglot-ts/issues"
	},
	"sideEffects": [
		"./dist/index.mjs",
		"./dist/expressions.mjs",
		"./dist/dialects/*.mjs"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"oxfmt": "0.34.0",
		"oxlint": "1.49.0",
		"tsdown": "0.20.3",
		"typescript": "^5.3.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
