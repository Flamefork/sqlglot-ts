{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "sqlglot-ts": ["../src/index.ts"],
      "sqlglot-ts/dialects": ["../src/dialects/index.ts"],
      "sqlglot-ts/dialects/*": ["../src/dialects/*.ts"],
      "sqlglot-ts/expressions": ["../src/expressions.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
